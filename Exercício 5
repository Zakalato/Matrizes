package Matrizes;
import java.util.Scanner;
public class Exercicio_5 {

    public static void preencheMatriz (int [][] matriz, Scanner s) {
        for(int i = 0; i < matriz.length;i++) {
            for(int j = 0; j < matriz[i].length;j++) {
                System.out.println("Informe o valor da posição [" + i + "][" + j + "]");
                matriz[i][j] = s.nextInt();
            }
        }
    }
    public static void Transposta (int [][] matriz, int [][] matrizTransposta) {
        for(int i = 0; i < matriz.length;i++) {
            for(int j = 0; j < matriz[i].length;j++) {
                matrizTransposta[j][i] = matriz[i][j];
            }
        }
    }

    public static void ImprimeMatriz (int [][] matrizTransposta) {
        for(int i = 0; i < matrizTransposta.length;i++) {
            for(int j = 0; j < matrizTransposta[i].length;j++) {
                System.out.print(matrizTransposta[i][j] + " ");
            }
            System.out.println();
        }
    }

    public static void main(String[] args) {
        Scanner s = new Scanner(System.in);
        int [][] matriz = new int[2][2];
        int [][] matrizTransposta = new int[2][2];
        preencheMatriz(matriz, s);
        Transposta(matriz, matrizTransposta);
        ImprimeMatriz(matrizTransposta);
        s.close();
    }

}
